---
interface Props {
  items: string[];
}
const { items } = Astro.props;
---
<div class="tldr-box">
  <div class="tldr-header">
    <span class="tldr-tag">// TL;DR</span>
    <span class="tldr-subtitle">Quick summary before you read</span>
  </div>
  <ul class="tldr-list">
    {items.map(item => (
      <li>
        <span class="tldr-check">✓</span>
        <span>{item}</span>
      </li>
    ))}
  </ul>
</div>

<style>
.tldr-box {
  background: rgba(123, 47, 255, 0.06);
  border: 1px solid rgba(123, 47, 255, 0.28);
  border-left: 4px solid var(--neon-purple);
  border-radius: 12px;
  padding: 1.5rem 1.75rem;
  margin-bottom: 0.5rem;
}

.tldr-header {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.tldr-tag {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--neon-purple);
}

.tldr-subtitle {
  font-size: 0.78rem;
  color: var(--text-muted);
  font-family: var(--font-mono);
}

.tldr-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  padding: 0;
}

.tldr-list li {
  display: flex;
  align-items: flex-start;
  gap: 0.65rem;
  font-size: 0.97rem;
  color: var(--text-secondary);
  line-height: 1.55;
}

.tldr-check {
  color: #4ade80;
  font-weight: 700;
  font-size: 0.85rem;
  flex-shrink: 0;
  margin-top: 0.1rem;
}
</style>
