---
interface Stat {
  value: string;
  label: string;
}
interface Props {
  stats: Stat[];
}
const { stats } = Astro.props;
---
<div class="stat-row">
  {stats.map(s => (
    <div class="stat-box">
      <span class="stat-value">{s.value}</span>
      <span class="stat-label">{s.label}</span>
    </div>
  ))}
</div>
