---
interface Props {
  activePage?: 'features' | 'blog' | 'about' | 'contact' | '';
}

const { activePage = '' } = Astro.props;

const links = [
  { href: '/',         label: 'Home',     key: 'home'     },
  { href: '/features', label: 'Features', key: 'features' },
  { href: '/blog/',    label: 'Blog',     key: 'blog'     },
  { href: '/about',   label: 'About',    key: 'about'    },
  { href: '/contact', label: 'Contact',  key: 'contact'  },
] as const;
---

<nav class="nav" role="navigation" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Hunter Vault Home">
      <img src="/assets/hunter-vault-logo.webp" alt="Hunter Vault" width="32" height="32" loading="eager" />
      HUNTER <span>VAULT</span>
    </a>
    <ul class="nav-links">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class={activePage === link.key ? 'active' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li><a href="/#download" class="nav-cta">Download Free</a></li>
    </ul>
  </div>
</nav>
