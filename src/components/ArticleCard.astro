---
interface Props {
  title: string;
  excerpt: string;
  category: string;
  date: Date;
  readTime: string;
  slug: string;
  image?: string;
  imageAlt?: string;
}
const { title, excerpt, category, date, readTime, slug, image, imageAlt } = Astro.props;

const catClass: Record<string, string> = {
  'Finance Tips': 'cat-finance',
  'Guide': 'cat-guide',
  'Update': 'cat-update',
  'Story': 'cat-story',
};
const cls = catClass[category] ?? 'cat-guide';

const formattedDate = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<article class="article-card">
  <a href={`/blog/${slug}/`} class="article-thumb">
    {image
      ? <img src={image} alt={imageAlt ?? title} loading="lazy" />
      : <div class="article-thumb-placeholder">📰</div>
    }
  </a>
  <div class="article-body">
    <div class="article-meta">
      <span class={`article-category ${cls}`}>{category}</span>
      <span class="article-date">{formattedDate}</span>
    </div>
    <h2 class="article-title">{title}</h2>
    <p class="article-excerpt">{excerpt}</p>
    <div class="article-footer">
      <span class="article-read-time">{readTime}</span>
      <a href={`/blog/${slug}/`} class="article-link">
        Read More
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</article>
