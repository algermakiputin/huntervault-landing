---
interface Props {
  number: string;
  title: string;
}
const { number, title } = Astro.props;
---
<div class="step-card">
  <div class="step-card-header">
    <span class="step-number">{number}</span>
    <span class="step-title">{title}</span>
  </div>
  <div class="step-card-body">
    <slot />
  </div>
</div>
