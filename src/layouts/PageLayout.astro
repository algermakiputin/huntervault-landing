---
import Header from '../components/Header.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  activePage?: 'features' | 'blog' | 'about' | 'contact' | '';
  structuredData?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = "https://huntervault.app/assets/og-image.jpg",
  activePage = "",
  structuredData,
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index, follow" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Hunter Vault" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;800;900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

  <link rel="stylesheet" href="/pages.css" />

  {structuredData && <script type="application/ld+json" set:html={structuredData} />}

  <slot name="head" />

  <!-- Meta Pixel Code -->
  <script is:inline>
  !function(f,b,e,v,n,t,s)
  {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
  n.callMethod.apply(n,arguments):n.queue.push(arguments)};
  if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
  n.queue=[];t=b.createElement(e);t.async=!0;
  t.src=v;s=b.getElementsByTagName(e)[0];
  s.parentNode.insertBefore(t,s)}(window, document,'script',
  'https://connect.facebook.net/en_US/fbevents.js');
  fbq('init', '1720235038986418');
  fbq('track', 'PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none"
  src="https://www.facebook.com/tr?id=1720235038986418&ev=PageView&noscript=1"
  /></noscript>
  <!-- End Meta Pixel Code -->

  <script is:inline>
    document.addEventListener('click', (e) => {
      const a = e.target.closest('a[href*="apps.apple.com"], a[href*="play.google.com"]');
      if (!a || !window.fbq) return;
      const platform = a.href.includes('apps.apple.com') ? 'app_store' : 'google_play';
      fbq('track', 'Lead', { content_name: platform + '_' + (location.pathname.replace(/\//g, '_') || 'home') });
    });
  </script>
</head>
<body>

  <Header activePage={activePage} />

  <slot />

  <footer class="page-footer">
    <div class="page-footer-inner">
      <div class="page-footer-logo">
        <img src="/assets/hunter-vault-logo.webp" alt="Hunter Vault" width="26" height="26" />
        <span class="footer-brand">HUNTER <em>VAULT</em></span>
      </div>
      <nav class="page-footer-links" aria-label="Footer navigation">
        <a href="/">Home</a>
        <a href="/features">Features</a>
        <a href="/safe-to-spend">Safe-to-Spend</a>
        <a href="/about">About</a>
        <a href="/blog/">Blog</a>
        <a href="/faq">FAQ</a>
        <a href="/contact">Contact</a>
        <a href="/privacy-policy.html">Privacy Policy</a>
      </nav>
      <p class="page-footer-copy">&copy; 2026 Hunter Vault. All rights reserved.</p>
    </div>
  </footer>

</body>
</html>
