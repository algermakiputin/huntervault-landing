---
import PageLayout from '../layouts/PageLayout.astro';

const faqItems = [
  {
    q: 'What does "safe to spend" mean?',
    a: "It's the money you can spend today after your bills, savings, debt payments, and buffer are protected — not just your leftover balance."
  },
  {
    q: 'How is this different from my bank balance?',
    a: "Your balance includes money already promised to bills and goals. Safe-to-Spend subtracts those first, so the number you see is actually yours to use."
  },
  {
    q: 'Does Hunter Vault connect to my bank?',
    a: "No. It's 100% offline with no account required. Your data stays on your device."
  }
];

// Update aggregateRating values with actual App Store / Google Play review data
const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "FAQPage",
      "mainEntity": faqItems.map(item => ({
        "@type": "Question",
        "name": item.q,
        "acceptedAnswer": { "@type": "Answer", "text": item.a }
      }))
    },
    {
      "@type": "SoftwareApplication",
      "name": "Hunter Vault",
      "operatingSystem": "iOS, Android",
      "applicationCategory": "FinanceApplication",
      "url": "https://huntervault.app/safe-to-spend/",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "reviewCount": "120"
      }
    }
  ]
});
---

<PageLayout
  title="Safe-to-Spend: Know What You Can Actually Spend | Hunter Vault"
  description="Your balance isn't your spending money. Safe-to-Spend shows what's left after bills, savings, debt, and buffer are protected — so you can spend without the guilt."
  canonical="https://huntervault.app/safe-to-spend/"
  activePage=""
  structuredData={structuredData}
>
  <script slot="head" is:inline>
    window.addEventListener('load', () => {
      if (window.fbq) fbq('track', 'ViewContent', { content_name: 'safe_to_spend_page' });
    });
  </script>

  <!-- Hero -->
  <section class="page-hero">
    <span class="page-hero-tag">// safe-to-spend</span>
    <h1>Know what's actually<br /><span class="hl">safe to spend</span></h1>
    <p>Your bank balance lies to you. It shows one number, but a big chunk of it is already spoken for. Safe-to-Spend shows what's left after bills, savings, debt payments, and buffer are protected — so you can spend without the guilt.</p>
    <div class="sts-store-btns">
      <a href="https://apps.apple.com/app/hunter-vault-finance-tracker/id6761086056" aria-label="Download on the App Store">
        <img src="/assets/app-store-button.png" alt="Download on the App Store" width="160" height="53" />
      </a>
      <a href="https://play.google.com/store/apps/details?id=com.hunter.vault" aria-label="Get it on Google Play">
        <img src="/assets/google-play-button.png" alt="Get it on Google Play" width="160" height="53" />
      </a>
    </div>
  
  </section>

  <div class="page-wrap">

    <!-- Balance ≠ Safe to Spend -->
    <div class="feat-section" style="border-top: none; padding-top: 3rem;">
      <div class="feature-highlight">
        <div class="feature-highlight-text">
          <span class="section-tag">// the real number</span>
          <h2 class="section-title">Balance is not the same as safe to spend</h2>
          <p>Most apps just show "remaining balance." That number feels safe right up until a bill clears. Safe-to-Spend is different: it's the money you can spend after your future is already covered. No surprises, no end-of-month panic.</p>
        </div>
        <div class="feature-highlight-visual">
          <div class="stat-pill"><span class="stat-pill-dot" style="background:#f87171;"></span> Bank balance — misleading</div>
          <div class="stat-pill"><span class="stat-pill-dot green"></span> Safe-to-Spend — what's actually yours</div>
          <div class="stat-pill"><span class="stat-pill-dot purple"></span> Bills protected before you see a number</div>
          <div class="stat-pill"><span class="stat-pill-dot gold"></span> No end-of-month panic</div>
        </div>
      </div>
    </div>

    <!-- How it works -->
    <div class="feat-section">
      <div class="feat-section-header">
        <span class="section-tag">// how it works</span>
        <h2 class="section-title">How it works</h2>
        <p class="section-desc">Hunter Vault reserves what matters before you see a single number — then divides what's left across the days until your next income.</p>
      </div>
      <div class="features-grid" style="padding-top: 0;">

        <div class="feature-card">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--neon-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>
            </svg>
          </div>
          <h2>Protected categories locked in first</h2>
          <p>Bills and buffer are reserved before anything else. They're off the table — your spending can't touch them.</p>
          <ul class="feat-list">
            <li>Bills deducted automatically</li>
            <li>Buffer reserved as a safety net</li>
            <li>Savings goals set aside upfront</li>
            <li>Debt payments locked in before you spend</li>
          </ul>
          <span class="feature-badge">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            Protected first
          </span>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--neon-purple)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h2>Divided across days until next income</h2>
          <p>What's left after protection gets divided across the days remaining until your next paycheck — so you always know what's safe today, not just for the whole month.</p>
          <ul class="feat-list">
            <li>Daily safe amount auto-calculated</li>
            <li>Adjusts as the period progresses</li>
            <li>Knows when your next income lands</li>
          </ul>
          <span class="feature-badge">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Today's amount
          </span>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
          </div>
          <h2>Early warning before you overspend</h2>
          <p>Your budget becomes a shield. When Safe-to-Spend is running low, you'll know before you overspend — not after the damage is done.</p>
          <ul class="feat-list">
            <li>Visual alert when spending is near the limit</li>
            <li>Know before the bill clears, not after</li>
            <li>No surprise shortfalls at month end</li>
          </ul>
          <span class="feature-badge">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            Early warning
          </span>
        </div>

      </div>
    </div>

    <!-- Screenshots (lazy loaded) -->
    <div class="feat-section">
      <div class="sts-ss-row">
        <img
          src="/assets/listing-ss/ios2.webp"
          alt="Hunter Vault showing Safe-to-Spend amount after bills and savings are deducted from balance"
          width="200"
          height="400"
          loading="lazy"
        />
        <img
          src="/assets/listing-ss/ios3.webp"
          alt="Hunter Vault budget overview with protected categories reserved before spending"
          width="200"
          height="400"
          loading="lazy"
        />
        <img
          src="/assets/listing-ss/ios4.webp"
          alt="Hunter Vault daily spending limit calculated from remaining safe balance"
          width="200"
          height="400"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Spend without the guilt -->
    <div class="feat-section">
      <div class="feature-highlight">
        <div class="feature-highlight-text">
          <span class="section-tag">// spend without the guilt</span>
          <h2 class="section-title">Spend without the guilt</h2>
          <p>This is the part people feel most. When you know your future is protected, spending stops being stressful. Buy the thing. Get the food delivery. You already know it's safe — because the money that mattered was set aside first.</p>
        </div>
        <div class="feature-highlight-visual">
          <div class="stat-pill"><span class="stat-pill-dot green"></span> Future protected before you spend</div>
          <div class="stat-pill"><span class="stat-pill-dot blue"></span> Guilt-free spending clarity</div>
          <div class="stat-pill"><span class="stat-pill-dot purple"></span> No mental math required</div>
          <div class="stat-pill"><span class="stat-pill-dot gold"></span> Confidence every transaction</div>
        </div>
      </div>
    </div>

    <!-- Private by default -->
    <div class="feat-section">
      <div class="feature-highlight" style="margin-bottom: 0;">
        <div class="feature-highlight-text">
          <span class="section-tag">// private by default</span>
          <h2 class="section-title">Private by default</h2>
          <p>Your numbers stay on your device. No bank connection, no account, no tracking. Hide your balances anytime, and share only milestones — never amounts.</p>
        </div>
        <div class="feature-highlight-visual">
          <div class="stat-pill"><span class="stat-pill-dot green"></span> No bank connection ever</div>
          <div class="stat-pill"><span class="stat-pill-dot blue"></span> 100% offline — data on your device</div>
          <div class="stat-pill"><span class="stat-pill-dot purple"></span> No account required</div>
          <div class="stat-pill"><span class="stat-pill-dot gold"></span> Hide balances anytime</div>
        </div>
      </div>
    </div>

    <!-- FAQ -->
    <div class="feat-section">
      <div class="feat-section-header">
        <span class="section-tag">// questions</span>
        <h2 class="section-title">Frequently asked questions</h2>
      </div>
      <div class="faq-list">
        {faqItems.map((item) => (
          <div class="faq-item">
            <button class="faq-q" aria-expanded="false">
              {item.q}
              <svg class="faq-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>
            <div class="faq-a">{item.a}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Closing CTA -->
    <div class="feat-closing">
      <span class="section-tag" style="color: var(--neon-blue);">// your next move</span>
      <h2>Know what's safe before your<br />next money move.</h2>
      <p>Hunter Vault protects your future first — then shows you what's actually safe to spend. No bank connection. No account. Free to start.</p>
      <a href="https://apps.apple.com/app/hunter-vault-finance-tracker/id6761086056" class="btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download Free
      </a>
      <a href="/features" class="btn-secondary" style="margin-top: 0.5rem;">See all features →</a>
    </div>

  </div>

  <script is:inline>
    document.querySelectorAll('.faq-q').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.faq-item.open').forEach(el => {
          el.classList.remove('open');
          el.querySelector('.faq-q').setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          item.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  </script>

</PageLayout>
