  <script>
    const PHP = new Intl.NumberFormat('en-PH', { style: 'currency', currency: 'PHP', minimumFractionDigits: 2, maximumFractionDigits: 2 });
    const PCT = (n: number) => (isFinite(n) ? n.toFixed(2) : '0.00') + '%';

    const DEFAULTS = {
      productCost: 100,
      sellingPrice: 299,
      shippingFee: 0,
      packagingCost: 10,
      otherCosts: 0,
      targetProfit: 100,
      commissionFee: 10,
      serviceFee: 12,
      transactionFee: 2,
      withholdingTax: 0.5,
    };

    const ids = Object.keys(DEFAULTS);
    const $ = (id: string) => document.getElementById(id) as HTMLInputElement;

    function readNum(id: string): number {
      const el = $(id);
      const v = parseFloat(el?.value ?? '');
      return isNaN(v) || v < 0 ? 0 : v;
    }

    // Count-up animator (respects reduced motion)
    const prefersReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const animState: Record<string, { from: number; raf: number }> = {};
    function animateValue(id: string, to: number) {
      const el = document.getElementById(id);
      if (!el) return;
      const state = animState[id] || { from: 0, raf: 0 };
      const from = state.from;
      if (prefersReduce || Math.abs(to - from) < 0.5) {
        el.textContent = PHP.format(to);
        animState[id] = { from: to, raf: 0 };
        return;
      }
      if (state.raf) cancelAnimationFrame(state.raf);
      const duration = 420;
      const start = performance.now();
      const tick = (now: number) => {
        const t = Math.min(1, (now - start) / duration);
        const eased = 1 - Math.pow(1 - t, 3);
        const v = from + (to - from) * eased;
        el.textContent = PHP.format(v);
        if (t < 1) animState[id] = { from: v, raf: requestAnimationFrame(tick) };
        else animState[id] = { from: to, raf: 0 };
      };
      animState[id] = { from, raf: requestAnimationFrame(tick) };
    }

    function calc() {
      const productCost   = readNum('productCost');
      const sellingPrice  = readNum('sellingPrice');
      const shippingFee   = readNum('shippingFee');
      const packagingCost = readNum('packagingCost');
      const otherCosts    = readNum('otherCosts');
      const targetProfit  = readNum('targetProfit');

      const commissionFee  = readNum('commissionFee');
      const serviceFee     = readNum('serviceFee');
      const transactionFee = readNum('transactionFee');
      const withholdingTax = readNum('withholdingTax');

      const totalFeeRatePct = commissionFee + serviceFee + transactionFee + withholdingTax;
      const totalFeeRate    = totalFeeRatePct / 100;

      const totalFees = sellingPrice * totalFeeRate;
      const totalCosts = productCost + packagingCost + shippingFee + otherCosts;
      const netPayout = sellingPrice - totalFees;
      const profit = netPayout - totalCosts;
      const profitMargin = sellingPrice > 0 ? (profit / sellingPrice) * 100 : 0;

      const denom = 1 - totalFeeRate;
      const breakEvenPrice = denom > 0 ? totalCosts / denom : Infinity;
      const suggestedPrice = denom > 0 ? (totalCosts + targetProfit) / denom : Infinity;

      // Render
      (document.getElementById('grossVal') as HTMLElement).textContent = PHP.format(sellingPrice);
      (document.getElementById('feesVal') as HTMLElement).textContent = '−' + PHP.format(totalFees);
      (document.getElementById('costsVal') as HTMLElement).textContent = '−' + PHP.format(totalCosts);
      (document.getElementById('netVal') as HTMLElement).textContent = PHP.format(netPayout);
      (document.getElementById('breakEvenVal') as HTMLElement).textContent = isFinite(breakEvenPrice) ? PHP.format(breakEvenPrice) : '—';
      (document.getElementById('feeRateVal') as HTMLElement).textContent = PCT(totalFeeRatePct);

      animateValue('profitAmount', profit);
      (document.getElementById('marginVal') as HTMLElement).textContent = PCT(profitMargin);
      (document.getElementById('netInline') as HTMLElement).textContent = PHP.format(netPayout);

      (document.getElementById('targetEcho') as HTMLElement).textContent = targetProfit.toLocaleString('en-PH', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
      (document.getElementById('suggestedVal') as HTMLElement).textContent = isFinite(suggestedPrice) ? PHP.format(suggestedPrice) : '—';

      (document.getElementById('flowSelling') as HTMLElement).textContent = PHP.format(sellingPrice);
      (document.getElementById('flowFees') as HTMLElement).textContent = PHP.format(totalFees);
      (document.getElementById('flowCosts') as HTMLElement).textContent = PHP.format(totalCosts);
      (document.getElementById('flowProfit') as HTMLElement).textContent = PHP.format(profit);

      // States
      const panel = document.getElementById('results') as HTMLElement;
      const profitLabel = document.getElementById('profitLabel') as HTMLElement;
      panel.classList.remove('state-warn', 'state-success');

      if (profit < 0) {
        panel.classList.add('state-warn');
        profitLabel.innerHTML = '⚠️ You’re Losing Money';
      } else if (targetProfit > 0 && profit >= targetProfit) {
        panel.classList.add('state-success');
        profitLabel.innerHTML = '✓ Target Profit Reached';
      } else {
        profitLabel.innerHTML = '⚡ Estimated Profit';
      }

      return { sellingPrice, totalFees, totalCosts, netPayout, profit, profitMargin, breakEvenPrice, suggestedPrice, totalFeeRatePct, targetProfit };
    }

    ids.forEach(id => {
      const el = $(id);
      if (el) el.addEventListener('input', calc);
    });

    (document.getElementById('btnReset') as HTMLButtonElement).addEventListener('click', () => {
      ids.forEach(id => { const el = $(id); if (el) el.value = String((DEFAULTS as any)[id]); });
      calc();
    });

    const PAGE_URL = 'https://huntervault.app/tools/shopee-profit-calculator/';

    function shortResult() {
      const r = calc();
      return [
        `Selling Price: ${PHP.format(r.sellingPrice)}`,
        `Total Fees: ${PHP.format(r.totalFees)}`,
        `Total Costs: ${PHP.format(r.totalCosts)}`,
        `Estimated Profit: ${PHP.format(r.profit)}`,
        `Profit Margin: ${PCT(r.profitMargin)}`,
        `Suggested Price: ${isFinite(r.suggestedPrice) ? PHP.format(r.suggestedPrice) : 'n/a'}`,
      ].join('\n');
    }

    function fullBreakdown() {
      const r = calc();
      return [
        `Shopee Profit Calculator — Hunter Vault`,
        ``,
        `Selling Price:       ${PHP.format(r.sellingPrice)}`,
        `Total Fees (${PCT(r.totalFeeRatePct)}):   ${PHP.format(r.totalFees)}`,
        `Total Costs:         ${PHP.format(r.totalCosts)}`,
        `Net Payout:          ${PHP.format(r.netPayout)}`,
        `Estimated Profit:    ${PHP.format(r.profit)}`,
        `Profit Margin:       ${PCT(r.profitMargin)}`,
        `Break-Even Price:    ${isFinite(r.breakEvenPrice) ? PHP.format(r.breakEvenPrice) : 'n/a'}`,
        `Suggested Price (₱${r.targetProfit} target): ${isFinite(r.suggestedPrice) ? PHP.format(r.suggestedPrice) : 'n/a'}`,
        ``,
        PAGE_URL,
      ].join('\n');
    }

    function flashCopied() {
      const c = document.getElementById('copyConfirm') as HTMLElement;
      c.classList.add('show');
      setTimeout(() => c.classList.remove('show'), 1800);
    }

    async function copyText(text: string) {
      try { await navigator.clipboard.writeText(text); flashCopied(); }
      catch (e) {
        const ta = document.createElement('textarea');
        ta.value = text; document.body.appendChild(ta); ta.select();
        try { document.execCommand('copy'); flashCopied(); } catch {}
        document.body.removeChild(ta);
      }
    }

    document.getElementById('btnCopyBreakdown')?.addEventListener('click', () => copyText(fullBreakdown()));
    document.getElementById('btnCopyResult')?.addEventListener('click', () => copyText(shortResult()));
    document.getElementById('btnShareResult')?.addEventListener('click', async () => {
      const text = shortResult() + '\n\nCalculate yours: ' + PAGE_URL;
      const nav = navigator as any;
      if (nav.share) {
        try { await nav.share({ title: 'Shopee Profit Calculator', text, url: PAGE_URL }); return; }
        catch (e) {}
      }
      copyText(text);
    });

    calc();

    // Mobile drawer
    const burger = document.getElementById('nav-burger') as HTMLButtonElement | null;
    const drawer = document.getElementById('nav-drawer') as HTMLElement | null;
    burger?.addEventListener('click', () => {
      const open = drawer!.classList.toggle('open');
      burger.classList.toggle('open', open);
      burger.setAttribute('aria-expanded', String(open));
      drawer!.setAttribute('aria-hidden', String(!open));
      document.body.classList.toggle('drawer-open', open);
    });
    drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      drawer.classList.remove('open');
      burger?.classList.remove('open');
      burger?.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('drawer-open');
    }));
  </script>
</body>
</html>
