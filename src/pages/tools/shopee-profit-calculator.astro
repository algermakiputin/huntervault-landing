---
const title = "Free Shopee Profit Calculator Philippines | Hunter Vault";
const description = "Calculate Shopee fees, net payout, profit margin, break-even price, and suggested selling price for Filipino sellers.";
const canonical = "https://huntervault.app/tools/shopee-profit-calculator/";
const ogImage = "https://huntervault.app/assets/og-image.jpg";

const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Shopee Profit Calculator",
  "url": canonical,
  "description": description,
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "PHP" },
  "publisher": { "@type": "Organization", "name": "Hunter Vault", "url": "https://huntervault.app" }
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index, follow" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Hunter Vault" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;800;900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={structuredData} />

  <!-- Meta Pixel Code -->
  <script is:inline>
  !function(f,b,e,v,n,t,s)
  {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
  n.callMethod.apply(n,arguments):n.queue.push(arguments)};
  if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
  n.queue=[];t=b.createElement(e);t.async=!0;
  t.src=v;s=b.getElementsByTagName(e)[0];
  s.parentNode.insertBefore(t,s)}(window, document,'script',
  'https://connect.facebook.net/en_US/fbevents.js');
  fbq('init', '1720235038986418');
  fbq('track', 'PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none"
  src="https://www.facebook.com/tr?id=1720235038986418&ev=PageView&noscript=1"
  /></noscript>
  <!-- End Meta Pixel Code -->

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:       #050812;
      --bg-card:  rgba(255,255,255,0.025);
      --purple:   #7b2fff;
      --violet:   #9b59ff;
      --cyan:     #00d4ff;
      --green:    #4ade80;
      --red:      #f87171;
      --gold:     #f5c400;
      --orange:   #ff6b35;
      --text-1:   #E6EAF2;
      --text-2:   #AAB2C0;
      --text-3:   #7F8A9A;
      --mono:     'JetBrains Mono', monospace;
      --display:  'Orbitron', sans-serif;
      --body:     'Inter', sans-serif;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--body); background: var(--bg); color: var(--text-1); line-height: 1.7; overflow-x: hidden; }
    a { text-decoration: none; color: inherit; }

    /* NAV */
    .site-nav { position: sticky; top: 0; z-index: 100; background: rgba(5,8,18,0.92); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(123,47,255,0.1); padding: 0 2rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { display: flex; align-items: center; gap: 0.6rem; font-family: var(--display); font-size: 0.9rem; font-weight: 700; letter-spacing: 1px; }
    .nav-logo img { width: 32px; height: 32px; object-fit: contain; }
    .nav-logo span { color: var(--purple); }
    .nav-links { display: flex; align-items: center; gap: 1.5rem; font-size: 0.85rem; color: var(--text-2); }
    .nav-links a:hover { color: var(--text-1); }
    .nav-active { color: var(--text-1) !important; font-weight: 600; }
    .nav-cta { background: var(--purple); color: #fff !important; padding: 0.45rem 1.1rem; border-radius: 8px; font-weight: 600; font-size: 0.85rem; transition: opacity 0.2s; }
    .nav-cta:hover { opacity: 0.85; }

    /* Mobile hamburger */
    .nav-burger { display: none; flex-direction: column; gap: 5px; background: none; border: none; padding: 6px; cursor: pointer; }
    .nav-burger span { display: block; width: 22px; height: 2px; background: var(--text-1); transition: transform 0.25s, opacity 0.2s; transform-origin: center; }
    .nav-burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-burger.open span:nth-child(2) { opacity: 0; }
    .nav-burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    @media (max-width: 640px) {
      .nav-links { display: none; }
      .nav-burger { display: flex; }
    }

    /* Mobile drawer */
    .nav-drawer { position: fixed; inset: 64px 0 0 0; background: rgba(5,8,18,0.98); backdrop-filter: blur(14px); z-index: 99; padding: 1.5rem 1.5rem 2rem; overflow-y: auto; transform: translateX(100%); transition: transform 0.28s ease; display: flex; flex-direction: column; gap: 0.5rem; }
    .nav-drawer.open { transform: translateX(0); }
    body.drawer-open { overflow: hidden; }
    .nd-tag { font-family: var(--mono); font-size: 0.58rem; color: var(--purple); letter-spacing: 2px; text-transform: uppercase; margin: 0.85rem 0 0.4rem; }
    .nd-tag:first-child { margin-top: 0; }
    .nd-item { display: flex; align-items: center; justify-content: space-between; padding: 0.85rem 1rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 10px; font-size: 0.95rem; color: var(--text-1); transition: background 0.15s; }
    .nd-item:hover { background: rgba(123,47,255,0.1); }
    .nd-item .arr { color: var(--text-3); }
    .nd-item-sub { display: block; font-size: 0.72rem; color: var(--text-3); margin-top: 0.15rem; font-weight: 400; }
    .nd-cta { display: flex; align-items: center; justify-content: center; gap: 0.5rem; background: linear-gradient(135deg, var(--purple), var(--cyan)); color: #fff !important; padding: 0.85rem 1rem; border-radius: 10px; font-weight: 700; font-size: 0.95rem; margin-top: 1rem; }

    /* Tools dropdown */
    .nav-dd { position: relative; display: inline-flex; }
    .nav-dd-btn { background: none; border: none; cursor: pointer; font: inherit; font-size: 0.85rem; color: var(--text-2); padding: 0; display: inline-flex; align-items: center; gap: 0.25rem; transition: color 0.2s; }
    .nav-dd-btn.nav-active { color: var(--text-1); font-weight: 600; }
    .nav-dd-btn svg { opacity: 0.7; transition: transform 0.2s; }
    .nav-dd:hover .nav-dd-btn svg, .nav-dd:focus-within .nav-dd-btn svg { transform: rotate(180deg); }
    .nav-dd-btn:hover { color: var(--text-1); }
    .nav-dd-menu { position: absolute; top: calc(100% + 14px); left: 50%; transform: translateX(-50%) translateY(-4px); min-width: 270px; background: rgba(10,14,28,0.97); border: 1px solid rgba(123,47,255,0.22); border-radius: 14px; padding: 0.75rem; box-shadow: 0 12px 36px rgba(0,0,0,0.55); backdrop-filter: blur(14px); opacity: 0; visibility: hidden; pointer-events: none; transition: opacity 0.18s, transform 0.18s, visibility 0.18s; z-index: 200; }
    .nav-dd-menu::before { content: ''; position: absolute; top: -7px; left: 50%; transform: translateX(-50%) rotate(45deg); width: 12px; height: 12px; background: rgba(10,14,28,0.97); border-left: 1px solid rgba(123,47,255,0.22); border-top: 1px solid rgba(123,47,255,0.22); }
    .nav-dd:hover .nav-dd-menu, .nav-dd:focus-within .nav-dd-menu { opacity: 1; visibility: visible; pointer-events: auto; transform: translateX(-50%) translateY(0); }
    .nav-dd-tag { display: block; font-family: var(--mono); font-size: 0.56rem; color: var(--violet); letter-spacing: 2px; text-transform: uppercase; padding: 0.3rem 0.7rem 0.5rem; }
    .nav-dd-item { display: flex; flex-direction: column; gap: 0.15rem; padding: 0.6rem 0.75rem; border-radius: 9px; transition: background 0.15s; color: var(--text-2) !important; }
    .nav-dd-item:hover { background: rgba(123,47,255,0.12); color: var(--text-1) !important; }
    .nav-dd-item-title { font-size: 0.85rem; font-weight: 600; color: var(--text-1); }
    .nav-dd-item-desc { font-size: 0.7rem; color: var(--text-3); line-height: 1.4; }

    /* HERO */
    .tool-hero { text-align: center; padding: 4.5rem 1.25rem 2.5rem; background: radial-gradient(ellipse 70% 50% at 50% 100%, rgba(255,107,53,0.13) 0%, transparent 70%); border-bottom: 1px solid rgba(255,107,53,0.08); }
    .tool-hero-tag { font-family: var(--mono); font-size: 0.62rem; color: var(--orange); letter-spacing: 3px; text-transform: uppercase; display: block; margin-bottom: 1.1rem; }
    .tool-hero h1 { font-family: var(--display); font-size: clamp(1.5rem, 4vw, 2.3rem); font-weight: 800; line-height: 1.2; max-width: 720px; margin: 0 auto 0.9rem; }
    .tool-hero h1 span { background: linear-gradient(135deg, var(--orange), var(--gold)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .tool-hero p { font-size: 1rem; color: var(--text-2); max-width: 540px; margin: 0 auto 0.6rem; }
    .tool-hero .hero-cta-line { font-family: var(--mono); font-size: 0.78rem; color: var(--text-3); max-width: 540px; margin: 0 auto 1.4rem; letter-spacing: 0.02em; }
    .hero-hv-tag { display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--mono); font-size: 0.65rem; color: var(--violet); background: rgba(123,47,255,0.08); border: 1px solid rgba(123,47,255,0.2); border-radius: 99px; padding: 0.3rem 0.8rem; letter-spacing: 0.05em; }

    /* MAIN WRAP */
    .tool-wrap { max-width: 1080px; margin: 0 auto; padding: 2.5rem 1.25rem 4rem; }

    /* TOOL COLUMNS */
    .tool-columns { display: grid; grid-template-columns: 1.05fr 1fr; gap: 1.25rem; margin-bottom: 1.5rem; align-items: start; }
    @media (max-width: 860px) { .tool-columns { grid-template-columns: 1fr; } }

    /* PANELS */
    .panel { background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.07); border-radius: 18px; padding: 1.5rem 1.5rem; }
    .panel-inputs { background: rgba(255,107,53,0.04); border: 1px solid rgba(255,107,53,0.18); }
    .panel-tag { font-family: var(--mono); font-size: 0.6rem; color: var(--orange); letter-spacing: 2px; text-transform: uppercase; display: block; margin-bottom: 0.3rem; }
    .panel-tag.cyan { color: var(--cyan); }
    .panel-title { font-family: var(--display); font-size: 1.05rem; margin-bottom: 1.25rem; }

    /* INPUT GROUPS */
    .input-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.85rem 1rem; }
    @media (max-width: 480px) { .input-grid { grid-template-columns: 1fr; } }
    .input-group { display: flex; flex-direction: column; gap: 0.35rem; }
    .input-group.full { grid-column: 1 / -1; }
    .input-label { font-family: var(--mono); font-size: 0.62rem; color: var(--text-2); letter-spacing: 1px; text-transform: uppercase; display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
    .input-label .hint { color: var(--text-3); text-transform: none; letter-spacing: 0; font-size: 0.6rem; }
    .input-wrap { position: relative; display: flex; align-items: center; }
    .input-prefix, .input-suffix { position: absolute; font-family: var(--mono); font-size: 0.78rem; color: var(--text-3); pointer-events: none; }
    .input-prefix { left: 0.75rem; }
    .input-suffix { right: 0.75rem; }
    .field { width: 100%; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 9px; padding: 0.7rem 0.85rem; color: var(--text-1); font-family: var(--mono); font-size: 0.95rem; font-weight: 500; transition: border-color 0.18s, background 0.18s; -moz-appearance: textfield; min-height: 44px; }
    .field::-webkit-outer-spin-button, .field::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    .field:focus { outline: none; border-color: var(--orange); background: rgba(255,107,53,0.05); }
    .field.has-prefix { padding-left: 1.85rem; }
    .field.has-suffix { padding-right: 1.85rem; }

    .section-divider { display: flex; align-items: center; gap: 0.65rem; margin: 1.4rem 0 0.9rem; font-family: var(--mono); font-size: 0.6rem; color: var(--text-3); letter-spacing: 1.5px; text-transform: uppercase; }
    .section-divider::after { content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.06); }

    /* ACTION ROW */
    .action-row { display: flex; gap: 0.5rem; margin-top: 1.25rem; flex-wrap: wrap; }
    .btn { border: none; border-radius: 9px; padding: 0.65rem 1.1rem; font-size: 0.82rem; font-weight: 600; cursor: pointer; transition: opacity 0.2s, transform 0.15s, background 0.2s; font-family: var(--body); letter-spacing: 0.02em; display: inline-flex; align-items: center; gap: 0.45rem; }
    .btn-primary { background: linear-gradient(135deg, var(--orange), var(--gold)); color: #1a0d00; flex: 1; min-width: 0; justify-content: center; }
    .btn-primary:hover { opacity: 0.92; transform: translateY(-1px); }
    .btn-ghost { background: rgba(255,255,255,0.04); color: var(--text-2); border: 1px solid rgba(255,255,255,0.08); }
    .btn-ghost:hover { background: rgba(255,255,255,0.08); color: var(--text-1); }

    /* RESULTS PANEL */
    .results-panel { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.07); border-radius: 18px; padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem; }
    .results-panel.state-warn { border-color: rgba(248,113,113,0.35); background: linear-gradient(180deg, rgba(248,113,113,0.04), rgba(255,255,255,0.02)); }
    .results-panel.state-success { border-color: rgba(74,222,128,0.35); background: linear-gradient(180deg, rgba(74,222,128,0.04), rgba(255,255,255,0.02)); }

    .result-headline { position: relative; background: radial-gradient(ellipse 80% 80% at 50% 0%, rgba(0,212,255,0.12), rgba(123,47,255,0.06) 60%, transparent); border: 1px solid rgba(0,212,255,0.22); border-radius: 14px; padding: 1.4rem 1.4rem 1.5rem; text-align: center; overflow: hidden; transition: background 0.25s, border-color 0.25s; }
    .result-headline::after { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 100%, rgba(0,212,255,0.08), transparent 50%); pointer-events: none; }
    .results-panel.state-warn .result-headline { background: radial-gradient(ellipse 80% 80% at 50% 0%, rgba(248,113,113,0.14), transparent 60%); border-color: rgba(248,113,113,0.32); }
    .results-panel.state-success .result-headline { background: radial-gradient(ellipse 80% 80% at 50% 0%, rgba(74,222,128,0.16), rgba(245,196,0,0.06) 60%, transparent); border-color: rgba(74,222,128,0.34); }
    .result-headline-label { font-family: var(--mono); font-size: 0.62rem; color: var(--text-3); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 0.5rem; display: flex; align-items: center; justify-content: center; gap: 0.4rem; position: relative; z-index: 1; }
    .result-headline-amount { font-family: var(--mono); font-size: clamp(2.6rem, 8vw, 3.4rem); font-weight: 800; color: var(--cyan); line-height: 1; margin-bottom: 0.45rem; letter-spacing: -0.02em; text-shadow: 0 0 28px rgba(0,212,255,0.45), 0 0 50px rgba(0,212,255,0.18); position: relative; z-index: 1; transition: color 0.25s, text-shadow 0.25s; }
    .results-panel.state-warn .result-headline-amount { color: var(--red); text-shadow: 0 0 28px rgba(248,113,113,0.5), 0 0 50px rgba(248,113,113,0.2); }
    .results-panel.state-success .result-headline-amount { color: var(--green); text-shadow: 0 0 28px rgba(74,222,128,0.5), 0 0 50px rgba(74,222,128,0.2); }
    .result-headline-sub { font-size: 0.82rem; color: var(--text-3); position: relative; z-index: 1; }
    .result-headline-sub strong { color: var(--text-1); font-weight: 700; font-family: var(--mono); }

    .result-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; }
    .result-stat { background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.05); border-radius: 10px; padding: 0.75rem 0.85rem; }
    .result-stat-label { font-family: var(--mono); font-size: 0.56rem; color: var(--text-3); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 0.25rem; }
    .result-stat-val { font-family: var(--mono); font-size: 0.95rem; font-weight: 700; color: var(--text-1); }
    .result-stat-val.neg { color: var(--red); }
    .result-stat-val.pos { color: var(--green); }
    .result-stat-val.cyan { color: var(--cyan); }
    .result-stat-val.gold { color: var(--gold); }

    .result-suggested { position: relative; background: linear-gradient(135deg, rgba(245,196,0,0.10), rgba(74,222,128,0.06)); border: 1px solid rgba(245,196,0,0.32); border-radius: 14px; padding: 1.15rem 1.25rem; overflow: hidden; }
    .result-suggested::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: linear-gradient(180deg, var(--gold), var(--green)); }
    .result-suggested-tag { font-family: var(--mono); font-size: 0.6rem; color: var(--gold); letter-spacing: 2px; text-transform: uppercase; display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.4rem; }
    .result-suggested-line { font-size: 0.86rem; color: var(--text-2); line-height: 1.55; }
    .result-suggested-line strong { font-family: var(--mono); color: var(--gold); font-weight: 700; }
    .result-suggested-price { display: block; font-family: var(--mono); font-size: 1.6rem; color: var(--gold); font-weight: 800; line-height: 1.1; margin-top: 0.45rem; letter-spacing: -0.01em; text-shadow: 0 0 16px rgba(245,196,0,0.25); }

    /* SHARE ROW */
    .share-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0.5rem; margin-top: 0.25rem; }
    @media (max-width: 380px) { .share-row { grid-template-columns: 1fr; } }
    .share-btn { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); color: var(--text-2); border-radius: 9px; padding: 0.6rem 0.6rem; font-size: 0.76rem; font-weight: 600; cursor: pointer; transition: background 0.15s, color 0.15s, border-color 0.15s; font-family: var(--body); display: inline-flex; align-items: center; justify-content: center; gap: 0.4rem; min-height: 42px; }
    .share-btn:hover { background: rgba(123,47,255,0.12); color: var(--text-1); border-color: rgba(123,47,255,0.3); }
    .share-btn svg { opacity: 0.7; }
    .copy-confirm { font-family: var(--mono); font-size: 0.7rem; color: var(--green); display: none; text-align: center; margin-top: 0.25rem; }
    .copy-confirm.show { display: block; }

    /* REALITY CHECK */
    .reality-check { margin-top: 2.5rem; background: rgba(255,255,255,0.025); border: 1px solid rgba(255,107,53,0.18); border-radius: 18px; padding: 1.75rem 1.5rem; }
    .reality-check-tag { font-family: var(--mono); font-size: 0.6rem; color: var(--orange); letter-spacing: 2.5px; text-transform: uppercase; display: block; margin-bottom: 0.7rem; }
    .reality-check h2 { font-family: var(--display); font-size: 1.15rem; margin-bottom: 0.4rem; }
    .reality-check p { font-size: 0.9rem; color: var(--text-2); max-width: 580px; margin-bottom: 1.4rem; }
    .reality-flow { display: grid; grid-template-columns: repeat(4, 1fr) auto auto auto 1fr; gap: 0; align-items: stretch; }
    .reality-flow { display: flex; align-items: stretch; gap: 0.5rem; flex-wrap: nowrap; overflow-x: auto; padding-bottom: 0.25rem; }
    .reality-step { flex: 1 0 110px; min-width: 0; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 12px; padding: 0.85rem 0.85rem; display: flex; flex-direction: column; gap: 0.3rem; }
    .reality-step.in { border-color: rgba(0,212,255,0.25); }
    .reality-step.fees { border-color: rgba(248,113,113,0.25); }
    .reality-step.costs { border-color: rgba(248,113,113,0.25); }
    .reality-step.out { border-color: rgba(74,222,128,0.3); background: rgba(74,222,128,0.06); }
    .reality-step-label { font-family: var(--mono); font-size: 0.54rem; color: var(--text-3); letter-spacing: 1.5px; text-transform: uppercase; }
    .reality-step-val { font-family: var(--mono); font-size: 1rem; font-weight: 700; color: var(--text-1); line-height: 1.1; }
    .reality-step.in .reality-step-val { color: var(--cyan); }
    .reality-step.fees .reality-step-val, .reality-step.costs .reality-step-val { color: var(--red); }
    .reality-step.out .reality-step-val { color: var(--green); }
    .reality-arrow { align-self: center; color: var(--text-3); font-size: 1rem; flex: 0 0 auto; padding: 0 0.1rem; }
    @media (max-width: 540px) {
      .reality-flow { flex-direction: column; }
      .reality-arrow { transform: rotate(90deg); padding: 0.25rem 0; }
      .reality-step { flex: 1 1 auto; }
    }

    /* COMING SOON */
    .coming-soon { margin-top: 2.5rem; }
    .coming-soon h2 { font-family: var(--display); font-size: 1.15rem; margin-bottom: 0.4rem; }
