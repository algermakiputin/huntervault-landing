      <div class="nav-dd">
        <button class="nav-dd-btn nav-active" aria-haspopup="true" aria-expanded="false" type="button">
          Tools
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="nav-dd-menu">
          <span class="nav-dd-tag">// Free Tools</span>
          <a href="/tools/savings-challenge-calculator/" class="nav-dd-item">
            <span class="nav-dd-item-title">Savings Challenge Calculator</span>
            <span class="nav-dd-item-desc">Turn savings into a daily XP game</span>
          </a>
          <a href="/tools/shopee-profit-calculator/" class="nav-dd-item">
            <span class="nav-dd-item-title">Shopee Profit Calculator</span>
            <span class="nav-dd-item-desc">Real profit after marketplace fees</span>
          </a>
        </div>
      </div>
      <a href="/contact">Contact</a>
      <a href="/#download" class="nav-cta">Download Free</a>
    </div>
    <button class="nav-burger" id="nav-burger" aria-label="Toggle menu" aria-expanded="false" type="button">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <div class="nav-drawer" id="nav-drawer" aria-hidden="true">
    <span class="nd-tag">// Navigation</span>
    <a href="/" class="nd-item">Home <span class="arr">›</span></a>
    <a href="/features" class="nd-item">Features <span class="arr">›</span></a>
    <a href="/blog/" class="nd-item">Blog <span class="arr">›</span></a>
    <a href="/about" class="nd-item">About <span class="arr">›</span></a>
    <a href="/contact" class="nd-item">Contact <span class="arr">›</span></a>

    <span class="nd-tag">// Free Tools</span>
    <a href="/tools/savings-challenge-calculator/" class="nd-item">
      <span>Savings Challenge Calculator<span class="nd-item-sub">Turn savings into a daily XP game</span></span>
      <span class="arr">›</span>
