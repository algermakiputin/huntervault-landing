        <a href="https://play.google.com/store/apps/details?id=com.hunter.vault" class="cta-store-btn" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302a1 1 0 0 1 0 1.38l-2.302 2.302L15.396 12l2.302-2.492zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"/></svg>
          Google Play
        </a>
        <a href="https://apps.apple.com/app/hunter-vault-finance-tracker/id6761086056" class="cta-store-btn" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          App Store
        </a>
      </div>
    </div>

  </div>

  <footer class="tool-footer">
    <p style="margin-bottom:0.4rem;">
      <a href="/">Home</a><a href="/features">Features</a><a href="/blog/">Blog</a>
      <a href="/faq">FAQ</a><a href="/contact">Contact</a><a href="/privacy-policy.html">Privacy</a>
    </p>
    <p>© 2026 Hunter Vault — Free tool, no account required.</p>
  </footer>

  <script>
    const BASE_URL = 'https://huntervault.app/tools/savings-challenge-calculator/';
    const EMBED_CODE = `<iframe src="${BASE_URL}?embed=1" width="100%" height="560" style="border:none;border-radius:16px;" title="Savings Challenge Calculator — Hunter Vault" loading="lazy"></iframe>`;

    // Embed mode
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('embed') === '1') document.body.classList.add('is-embed');

    // State
    let goal = 500, days = 60, xp = 20;

    const levels: Record<string, string> = {
      speed: 'SPEED RUNNER',
      consistency: 'CONSISTENCY BUILDER',
      endurance: 'ENDURANCE HUNTER',
      legendary: 'LEGENDARY GRINDER',
    };

    function getLevel(d: number) {
      if (d < 30)  return levels.speed;
      if (d <= 60) return levels.consistency;
      if (d <= 90) return levels.endurance;
      return levels.legendary;
    }

    function fmt(n: number) { return n.toFixed(2); }
    function fmtInt(n: number) { return Math.round(n).toLocaleString(); }

    // Live preview update
    function updatePreview() {
      const daily   = goal / days;
      const weekly  = daily * 7;
      const weeklyXP = xp * 7;
      const totalXP  = xp * days;
      const mid = Math.round(days / 2);

      (document.getElementById('prev-daily')    as HTMLElement).textContent = `$${fmt(daily)}`;
      (document.getElementById('prev-weekly')   as HTMLElement).textContent = `$${fmt(weekly)}`;
      (document.getElementById('prev-xp')       as HTMLElement).textContent = `${weeklyXP} XP`;
      (document.getElementById('prev-days')     as HTMLElement).textContent = String(days);
      (document.getElementById('prev-total-xp') as HTMLElement).textContent = fmtInt(totalXP);
      (document.getElementById('prev-midpoint') as HTMLElement).textContent = `Day ${mid}`;
      (document.getElementById('prev-endpoint') as HTMLElement).textContent = `Day ${days}`;
      (document.getElementById('prev-mid-label') as HTMLElement).textContent = `$${fmt(goal / 2)} saved`;
      (document.getElementById('prev-end-label') as HTMLElement).textContent = `$${fmt(goal)} ✓`;
    }

    // Sliders
    const goalSlider = document.getElementById('sc-goal') as HTMLInputElement;
    const daysSlider = document.getElementById('sc-days') as HTMLInputElement;
    const goalDisplay = document.getElementById('goal-display') as HTMLElement;
    const daysDisplay = document.getElementById('days-display') as HTMLElement;

    // Pre-fill from URL
    if (urlParams.get('goal')) { goal = +urlParams.get('goal')!; goalSlider.value = String(goal); }
    if (urlParams.get('days')) { days = +urlParams.get('days')!; daysSlider.value = String(days); }
    if (urlParams.get('xp'))   { xp   = +urlParams.get('xp')!; }

    goalDisplay.textContent = `$${goal.toLocaleString()}`;
    daysDisplay.textContent = `${days} days`;
    updatePreview();

    goalSlider.addEventListener('input', () => {
      goal = +goalSlider.value;
      goalDisplay.textContent = `$${goal.toLocaleString()}`;
      updatePreview();
    });

    daysSlider.addEventListener('input', () => {
      days = +daysSlider.value;
      daysDisplay.textContent = `${days} day${days !== 1 ? 's' : ''}`;
      updatePreview();
    });

    // XP presets
    document.querySelectorAll<HTMLButtonElement>('.xp-preset').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.xp-preset').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        xp = +btn.dataset.xp!;
        updatePreview();
      });
    });

    // Count-up animation
    function countUp(el: HTMLElement, target: number, prefix = '', suffix = '', duration = 700) {
      const start = performance.now();
      const from = 0;
      function tick(now: number) {
        const p = Math.min((now - start) / duration, 1);
        const ease = 1 - Math.pow(1 - p, 3);
        const val = from + (target - from) * ease;
        el.textContent = prefix + fmt(val) + suffix;
        if (p < 1) requestAnimationFrame(tick);
        else el.textContent = prefix + fmt(target) + suffix;
      }
      requestAnimationFrame(tick);
    }

    // Generate
    function generate() {
      const daily   = goal / days;
      const weekly  = daily * 7;
      const weeklyXP = xp * 7;

      // Update URL
      const u = new URL(window.location.href);
      u.searchParams.set('goal', String(goal));
      u.searchParams.set('days', String(days));
      u.searchParams.set('xp',   String(xp));
      history.replaceState(null, '', u.toString());

      // Badge + identity
      const level = getLevel(days);
      (document.getElementById('res-badge')  as HTMLElement).textContent = `🔥 Your ${days}-Day Challenge`;
      (document.getElementById('res-title')  as HTMLElement).textContent = `Save $${fmt(daily)}/day for ${days} days`;
      (document.getElementById('res-level')  as HTMLElement).textContent = `// ${level} · LVL UP UNLOCKED`;
      (document.getElementById('res-prog-label') as HTMLElement).textContent = `Day 0 of ${days}`;

      // Count-up stats
      const resDaily  = document.getElementById('res-daily')!;
      const resWeekly = document.getElementById('res-weekly')!;
      const resXP     = document.getElementById('res-xp')!;
      countUp(resDaily,  daily,   '$', '', 700);
      countUp(resWeekly, weekly,  '$', '', 850);
      resXP.textContent = `${weeklyXP} XP`;

      // Mission text
      (document.getElementById('res-mission') as HTMLElement).innerHTML =
        `<strong>Your mission:</strong> Save <strong>$${fmt(daily)}</strong> every day. Earn <strong>${xp} XP</strong> each time you complete it. Hit <strong>$${fmt(weekly)}</strong> by end of every week.`;

      // Animate progress bar
      const bar = document.getElementById('res-bar')!;
      bar.style.width = '0%';
      setTimeout(() => { bar.style.width = '3%'; }, 100);

      // Show result + share
      const card = document.getElementById('result-card')!;
      card.hidden = false;
      card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      (document.getElementById('share-block') as HTMLElement).hidden = false;
    }

    document.getElementById('sc-submit')?.addEventListener('click', generate);

    // Auto-generate if URL has params
    if (urlParams.get('goal') && urlParams.get('days') && urlParams.get('xp')) generate();

    // Share buttons
    document.getElementById('btn-copy-link')?.addEventListener('click', async () => {
      await navigator.clipboard.writeText(window.location.href);
      const confirm = document.getElementById('copy-confirm')!;
      confirm.classList.add('show');
      setTimeout(() => confirm.classList.remove('show'), 2000);
    });
    document.getElementById('btn-share-x')?.addEventListener('click', () => {
      const text = encodeURIComponent(`I just set a $${goal} savings challenge in ${days} days using this free tool:`);
      window.open(`https://twitter.com/intent/tweet?text=${text}&url=${encodeURIComponent(window.location.href)}`, '_blank');
    });
    document.getElementById('btn-share-fb')?.addEventListener('click', () => {
      window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(window.location.href)}`, '_blank');
    });
    document.getElementById('btn-share-reddit')?.addEventListener('click', () => {
      const t = encodeURIComponent('Free gamified savings challenge calculator — turns your goal into daily XP missions');
      window.open(`https://reddit.com/submit?url=${encodeURIComponent(window.location.href)}&title=${t}`, '_blank');
    });
    document.getElementById('btn-share-wa')?.addEventListener('click', () => {
      window.open(`https://wa.me/?text=${encodeURIComponent('Check out this free savings challenge calculator: ' + window.location.href)}`, '_blank');
    });

    // Embed toggle
    const embedToggle = document.getElementById('embed-toggle')!;
    const embedPanel  = document.getElementById('embed-panel')!;
    document.getElementById('embed-code-display')!.textContent = EMBED_CODE;
    embedToggle.addEventListener('click', () => {
      const open = embedPanel.hidden;
      embedPanel.hidden = !open;
      embedToggle.classList.toggle('open', open);
    });
    document.getElementById('btn-copy-embed')?.addEventListener('click', async () => {
      await navigator.clipboard.writeText(EMBED_CODE);
      const btn = document.getElementById('btn-copy-embed')!;
      btn.textContent = '✓ Copied!';
      setTimeout(() => { btn.textContent = 'Copy Code'; }, 2000);
    });

    // FAQ accordion
    document.querySelectorAll<HTMLButtonElement>('.faq-q').forEach(btn => {
      btn.addEventListener('click', () => btn.closest('.faq-item')!.classList.toggle('open'));
    });

    // Mobile drawer
    const burger = document.getElementById('nav-burger') as HTMLButtonElement | null;
    const drawer = document.getElementById('nav-drawer') as HTMLElement | null;
    burger?.addEventListener('click', () => {
      const open = drawer!.classList.toggle('open');
      burger.classList.toggle('open', open);
      burger.setAttribute('aria-expanded', String(open));
      drawer!.setAttribute('aria-hidden', String(!open));
      document.body.classList.toggle('drawer-open', open);
    });
    drawer?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      drawer.classList.remove('open');
      burger?.classList.remove('open');
      burger?.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('drawer-open');
    }));
  </script>

</body>
</html>
