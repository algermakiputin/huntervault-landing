---
const title = "Savings Challenge Calculator — Build Your Money Game Mission | Hunter Vault";
const description = "Free gamified savings calculator. Set your goal, get your daily mission, XP target, and weekly savings plan. Turn saving into a game you'll actually keep playing.";
const canonical = "https://huntervault.app/tools/savings-challenge-calculator/";
const ogImage = "https://huntervault.app/assets/og-image.jpg";

const structuredData = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Savings Challenge Calculator",
  "url": canonical,
  "description": description,
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "publisher": { "@type": "Organization", "name": "Hunter Vault", "url": "https://huntervault.app" }
});

const faqLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How does the savings challenge calculator work?", "acceptedAnswer": { "@type": "Answer", "text": "Enter your savings goal and timeframe using the sliders, then pick your XP level. The calculator instantly shows your daily savings mission, weekly target, and XP goal — turning your plan into a gamified daily challenge." } },
    { "@type": "Question", "name": "What is XP in a savings challenge?", "acceptedAnswer": { "@type": "Answer", "text": "XP (Experience Points) rewards you for completing daily financial habits — logging expenses, hitting your daily savings target, or completing a no-spend day. It makes progress feel rewarding even when the amounts are small." } },
    { "@type": "Question", "name": "How much should I save per day?", "acceptedAnswer": { "@type": "Answer", "text": "Start small — $1 to $5 per day builds the habit first. Use the slider to find a daily target that fits your income. Consistency matters more than the amount in the early weeks." } },
    { "@type": "Question", "name": "Can I share my savings challenge?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — after generating your plan, a shareable link is created that pre-fills your exact goal and timeframe for anyone who opens it." } },
    { "@type": "Question", "name": "Can I embed this calculator on my blog?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, completely free. Expand the Embed section and copy the iframe code — works on any platform that supports iframes." } }
  ]
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index, follow" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Hunter Vault" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png" />
  <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;800;900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <script type="application/ld+json" set:html={structuredData} />
  <script type="application/ld+json" set:html={faqLd} />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:       #050812;
      --bg-card:  rgba(255,255,255,0.025);
      --purple:   #7b2fff;
      --violet:   #9b59ff;
      --cyan:     #00d4ff;
      --green:    #4ade80;
      --red:      #f87171;
      --gold:     #f5c400;
      --text-1:   #E6EAF2;
      --text-2:   #AAB2C0;
      --text-3:   #7F8A9A;
      --mono:     'JetBrains Mono', monospace;
      --display:  'Orbitron', sans-serif;
      --body:     'Inter', sans-serif;
      --radius:   12px;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--body); background: var(--bg); color: var(--text-1); line-height: 1.7; overflow-x: hidden; }
    a { text-decoration: none; color: inherit; }

    /* NAV */
    .site-nav { position: sticky; top: 0; z-index: 100; background: rgba(5,8,18,0.92); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(123,47,255,0.1); padding: 0 2rem; height: 64px; display: flex; align-items: center; justify-content: space-between; }
    .nav-logo { display: flex; align-items: center; gap: 0.6rem; font-family: var(--display); font-size: 0.9rem; font-weight: 700; letter-spacing: 1px; }
    .nav-logo img { width: 32px; height: 32px; object-fit: contain; }
    .nav-logo span { color: var(--purple); }
    .nav-links { display: flex; align-items: center; gap: 1.5rem; font-size: 0.85rem; color: var(--text-2); }
    .nav-links a:hover { color: var(--text-1); }
    .nav-active { color: var(--text-1) !important; font-weight: 600; }
    .nav-cta { background: var(--purple); color: #fff !important; padding: 0.45rem 1.1rem; border-radius: 8px; font-weight: 600; font-size: 0.85rem; transition: opacity 0.2s; }
    .nav-cta:hover { opacity: 0.85; }

    /* Mobile hamburger */
    .nav-burger { display: none; flex-direction: column; gap: 5px; background: none; border: none; padding: 6px; cursor: pointer; }
    .nav-burger span { display: block; width: 22px; height: 2px; background: var(--text-1); transition: transform 0.25s, opacity 0.2s; transform-origin: center; }
    .nav-burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav-burger.open span:nth-child(2) { opacity: 0; }
    .nav-burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    @media (max-width: 640px) {
      .nav-links { display: none; }
      .nav-burger { display: flex; }
    }

    /* Mobile drawer */
    .nav-drawer { position: fixed; inset: 64px 0 0 0; background: rgba(5,8,18,0.98); backdrop-filter: blur(14px); z-index: 99; padding: 1.5rem 1.5rem 2rem; overflow-y: auto; transform: translateX(100%); transition: transform 0.28s ease; display: flex; flex-direction: column; gap: 0.5rem; }
    .nav-drawer.open { transform: translateX(0); }
    body.drawer-open { overflow: hidden; }
    .nd-tag { font-family: var(--mono); font-size: 0.58rem; color: var(--purple); letter-spacing: 2px; text-transform: uppercase; margin: 0.85rem 0 0.4rem; }
    .nd-tag:first-child { margin-top: 0; }
    .nd-item { display: flex; align-items: center; justify-content: space-between; padding: 0.85rem 1rem; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 10px; font-size: 0.95rem; color: var(--text-1); transition: background 0.15s; }
    .nd-item:hover { background: rgba(123,47,255,0.1); }
    .nd-item .arr { color: var(--text-3); }
    .nd-item-sub { display: block; font-size: 0.72rem; color: var(--text-3); margin-top: 0.15rem; font-weight: 400; }
    .nd-cta { display: flex; align-items: center; justify-content: center; gap: 0.5rem; background: linear-gradient(135deg, var(--purple), var(--cyan)); color: #fff !important; padding: 0.85rem 1rem; border-radius: 10px; font-weight: 700; font-size: 0.95rem; margin-top: 1rem; }

    /* Tools dropdown */
    .nav-dd { position: relative; display: inline-flex; }
    .nav-dd-btn { background: none; border: none; cursor: pointer; font: inherit; font-size: 0.85rem; color: var(--text-2); padding: 0; display: inline-flex; align-items: center; gap: 0.25rem; transition: color 0.2s; }
    .nav-dd-btn.nav-active { color: var(--text-1); font-weight: 600; }
    .nav-dd-btn svg { opacity: 0.7; transition: transform 0.2s; }
    .nav-dd:hover .nav-dd-btn svg, .nav-dd:focus-within .nav-dd-btn svg { transform: rotate(180deg); }
    .nav-dd-btn:hover { color: var(--text-1); }
    .nav-dd-menu { position: absolute; top: calc(100% + 14px); left: 50%; transform: translateX(-50%) translateY(-4px); min-width: 270px; background: rgba(10,14,28,0.97); border: 1px solid rgba(123,47,255,0.22); border-radius: 14px; padding: 0.75rem; box-shadow: 0 12px 36px rgba(0,0,0,0.55); backdrop-filter: blur(14px); opacity: 0; visibility: hidden; pointer-events: none; transition: opacity 0.18s, transform 0.18s, visibility 0.18s; z-index: 200; }
    .nav-dd-menu::before { content: ''; position: absolute; top: -7px; left: 50%; transform: translateX(-50%) rotate(45deg); width: 12px; height: 12px; background: rgba(10,14,28,0.97); border-left: 1px solid rgba(123,47,255,0.22); border-top: 1px solid rgba(123,47,255,0.22); }
    .nav-dd:hover .nav-dd-menu, .nav-dd:focus-within .nav-dd-menu { opacity: 1; visibility: visible; pointer-events: auto; transform: translateX(-50%) translateY(0); }
    .nav-dd-tag { display: block; font-family: var(--mono); font-size: 0.56rem; color: var(--violet); letter-spacing: 2px; text-transform: uppercase; padding: 0.3rem 0.7rem 0.5rem; }
    .nav-dd-item { display: flex; flex-direction: column; gap: 0.15rem; padding: 0.6rem 0.75rem; border-radius: 9px; transition: background 0.15s; color: var(--text-2) !important; }
    .nav-dd-item:hover { background: rgba(123,47,255,0.12); color: var(--text-1) !important; }
    .nav-dd-item-title { font-size: 0.85rem; font-weight: 600; color: var(--text-1); }
    .nav-dd-item-desc { font-size: 0.7rem; color: var(--text-3); line-height: 1.4; }

    /* HERO */
    .tool-hero { text-align: center; padding: 4.5rem 2rem 2.5rem; background: radial-gradient(ellipse 70% 50% at 50% 100%, rgba(123,47,255,0.13) 0%, transparent 70%); border-bottom: 1px solid rgba(123,47,255,0.07); }
    .tool-hero-tag { font-family: var(--mono); font-size: 0.62rem; color: var(--purple); letter-spacing: 3px; text-transform: uppercase; display: block; margin-bottom: 1.1rem; }
    .tool-hero h1 { font-family: var(--display); font-size: clamp(1.5rem, 3.5vw, 2.2rem); font-weight: 800; line-height: 1.2; max-width: 680px; margin: 0 auto 0.9rem; }
    .tool-hero h1 span { background: linear-gradient(135deg, var(--purple), var(--cyan)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .tool-hero p { font-size: 1rem; color: var(--text-2); max-width: 420px; margin: 0 auto 2rem; }

    /* SOCIAL PROOF STRIP */
    .proof-strip { display: flex; align-items: center; justify-content: center; gap: 0.5rem 1.75rem; flex-wrap: wrap; font-family: var(--mono); font-size: 0.72rem; color: var(--text-3); }
    .proof-strip strong { color: var(--text-2); }
    .proof-sep { opacity: 0.3; }

    /* MAIN WRAP */
    .tool-wrap { max-width: 960px; margin: 0 auto; padding: 3rem 2rem 5rem; }

    /* TOOL COLUMNS */
    .tool-columns { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem; }
    @media (max-width: 720px) { .tool-columns { grid-template-columns: 1fr; } }

    /* INPUTS PANEL */
    .inputs-panel { background: rgba(123,47,255,0.05); border: 1px solid rgba(123,47,255,0.2); border-radius: 18px; padding: 1.75rem 1.75rem; }
    .panel-tag { font-family: var(--mono); font-size: 0.6rem; color: var(--purple); letter-spacing: 2px; text-transform: uppercase; display: block; margin-bottom: 0.4rem; }
    .panel-title { font-family: var(--display); font-size: 1.1rem; margin-bottom: 1.5rem; }

    /* SLIDERS */
    .slider-group { margin-bottom: 1.5rem; }
    .slider-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.5rem; }
    .slider-label { font-family: var(--mono); font-size: 0.65rem; color: var(--cyan); letter-spacing: 1px; text-transform: uppercase; }
    .slider-val { font-family: var(--mono); font-size: 1.05rem; font-weight: 700; color: var(--text-1); }
    .slider-hint { font-family: var(--mono); font-size: 0.6rem; color: var(--text-3); margin-top: 0.3rem; }

    input[type="range"] {
      -webkit-appearance: none; appearance: none;
      width: 100%; height: 4px;
      background: rgba(255,255,255,0.08);
      border-radius: 99px; outline: none; cursor: pointer;
      accent-color: var(--purple);
    }
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none; appearance: none;
      width: 18px; height: 18px; border-radius: 50%;
      background: linear-gradient(135deg, var(--purple), var(--cyan));
      cursor: pointer; border: 2px solid var(--bg);
      box-shadow: 0 0 8px rgba(123,47,255,0.5);
      transition: box-shadow 0.2s;
    }
    input[type="range"]::-webkit-slider-thumb:hover { box-shadow: 0 0 14px rgba(123,47,255,0.8); }
    input[type="range"]::-moz-range-thumb { width: 18px; height: 18px; border-radius: 50%; background: linear-gradient(135deg, var(--purple), var(--cyan)); cursor: pointer; border: 2px solid var(--bg); }

    /* XP PRESETS */
    .xp-label { font-family: var(--mono); font-size: 0.65rem; color: var(--cyan); letter-spacing: 1px; text-transform: uppercase; display: block; margin-bottom: 0.6rem; }
    .xp-presets { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; margin-bottom: 1.5rem; }
    .xp-preset { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; padding: 0.55rem 0.5rem; text-align: center; cursor: pointer; transition: all 0.18s; font-family: var(--body); color: var(--text-2); }
    .xp-preset:hover { border-color: rgba(123,47,255,0.4); background: rgba(123,47,255,0.06); }
    .xp-preset.active { border-color: var(--purple); background: rgba(123,47,255,0.12); color: var(--text-1); }
    .xp-preset-name { display: block; font-size: 0.82rem; font-weight: 600; }
    .xp-preset-xp { display: block; font-family: var(--mono); font-size: 0.62rem; color: var(--cyan); margin-top: 0.1rem; }
    .xp-preset-hint { display: block; font-size: 0.62rem; color: var(--text-3); margin-top: 0.2rem; }

    /* CTA BUTTON */
    .gen-btn { width: 100%; background: linear-gradient(135deg, var(--purple), var(--cyan)); color: #fff; border: none; border-radius: 10px; padding: 0.85rem 1.5rem; font-size: 0.95rem; font-weight: 700; cursor: pointer; transition: opacity 0.2s, transform 0.2s, box-shadow 0.2s; letter-spacing: 0.02em; }
    .gen-btn:hover { opacity: 0.9; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(123,47,255,0.35); }

    /* LIVE PREVIEW PANEL */
    .preview-panel { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.07); border-radius: 18px; padding: 1.75rem; display: flex; flex-direction: column; gap: 1.25rem; }
    .preview-header { font-family: var(--mono); font-size: 0.6rem; color: var(--text-3); letter-spacing: 2px; text-transform: uppercase; }
    .preview-mission { background: rgba(123,47,255,0.07); border: 1px solid rgba(123,47,255,0.2); border-radius: 12px; padding: 1.1rem 1.25rem; }
    .preview-mission-day { font-family: var(--mono); font-size: 0.6rem; color: var(--purple); letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 0.3rem; }
    .preview-mission-amount { font-family: var(--mono); font-size: 2rem; font-weight: 700; color: var(--cyan); line-height: 1; margin-bottom: 0.2rem; }
    .preview-mission-label { font-size: 0.78rem; color: var(--text-3); }

    .preview-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 0.65rem; }
    .preview-stat { background: rgba(255,255,255,0.03); border-radius: 10px; padding: 0.8rem; }
    .preview-stat-label { font-family: var(--mono); font-size: 0.58rem; color: var(--text-3); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 0.2rem; }
    .preview-stat-val { font-family: var(--mono); font-size: 1rem; font-weight: 700; color: var(--text-1); }

    /* PROGRESS BAR */
    .preview-progress { }
    .preview-progress-header { display: flex; justify-content: space-between; font-family: var(--mono); font-size: 0.62rem; color: var(--text-3); margin-bottom: 0.5rem; }
    .preview-bar-track { height: 6px; background: rgba(255,255,255,0.06); border-radius: 99px; overflow: hidden; }
    .preview-bar-fill { height: 100%; background: linear-gradient(90deg, var(--purple), var(--cyan)); border-radius: 99px; transition: width 0.4s ease; width: 0%; }
    .preview-bar-milestones { display: flex; justify-content: space-between; margin-top: 0.3rem; font-family: var(--mono); font-size: 0.55rem; color: var(--text-3); }

    /* RESULT CARD */
    .result-card[hidden] { display: none !important; }
    .result-card { border: 1px solid rgba(123,47,255,0.28); border-radius: 20px; overflow: hidden; margin-bottom: 2.5rem; animation: slideUp 0.35s ease; }
    @keyframes slideUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

    .result-header { background: linear-gradient(135deg, rgba(123,47,255,0.18), rgba(0,212,255,0.08)); padding: 1.5rem 2rem; border-bottom: 1px solid rgba(123,47,255,0.15); }
    .result-identity { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
    .result-badge { font-family: var(--mono); font-size: 0.65rem; color: var(--purple); background: rgba(123,47,255,0.15); border: 1px solid rgba(123,47,255,0.3); border-radius: 100px; padding: 0.2rem 0.7rem; letter-spacing: 1px; text-transform: uppercase; }
    .result-title { font-family: var(--display); font-size: 1.2rem; font-weight: 800; }
    .result-level { font-family: var(--mono); font-size: 0.7rem; color: var(--gold); letter-spacing: 1px; margin-top: 0.2rem; }

    .result-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; }
    @media (max-width: 580px) { .result-stats { grid-template-columns: 1fr; } }
    .result-stat { padding: 1.5rem; border-right: 1px solid rgba(255,255,255,0.05); text-align: center; }
    .result-stat:last-child { border-right: none; }
    .result-stat-icon { font-size: 1.4rem; display: block; margin-bottom: 0.5rem; }
    .result-stat-label { font-family: var(--mono); font-size: 0.6rem; color: var(--text-3); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 0.35rem; display: block; }
    .result-stat-val { font-family: var(--mono); font-size: 1.5rem; font-weight: 700; color: var(--cyan); }

    .result-progress { padding: 1.25rem 2rem; border-top: 1px solid rgba(255,255,255,0.04); }
    .result-progress-label { font-family: var(--mono); font-size: 0.6rem; color: var(--text-3); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 0.6rem; display: flex; justify-content: space-between; }
    .result-bar-track { height: 8px; background: rgba(255,255,255,0.05); border-radius: 99px; overflow: hidden; margin-bottom: 0.5rem; }
    .result-bar-fill { height: 100%; background: linear-gradient(90deg, var(--purple), var(--cyan)); border-radius: 99px; width: 0%; transition: width 1s cubic-bezier(0.16, 1, 0.3, 1); }
    .result-mission { padding: 1rem 2rem 1.5rem; }
    .result-mission p { font-size: 0.9rem; color: var(--text-2); background: rgba(74,222,128,0.05); border: 1px solid rgba(74,222,128,0.15); border-radius: 10px; padding: 0.85rem 1.1rem; }
    .result-mission strong { color: var(--green); }

    /* SHARE (appears after result) */
    .share-block[hidden] { display: none !important; }
    .share-block { margin-bottom: 2.5rem; }
    .share-block-inner { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
    .share-label-text { font-family: var(--mono); font-size: 0.65rem; color: var(--text-3); letter-spacing: 1.5px; text-transform: uppercase; }
    .share-icon-btn { display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 8px; border: none; cursor: pointer; transition: opacity 0.2s, transform 0.2s; }
    .share-icon-btn:hover { opacity: 0.8; transform: translateY(-1px); }
    .si-copy   { background: rgba(123,47,255,0.15); border: 1px solid rgba(123,47,255,0.3); color: var(--violet); }
    .si-x      { background: #000; color: #fff; }
    .si-fb     { background: #1877F2; color: #fff; }
    .si-reddit { background: #FF4500; color: #fff; }
    .si-wa     { background: #25D366; color: #fff; }
    .share-copy-confirm { font-family: var(--mono); font-size: 0.72rem; color: var(--green); display: none; }
    .share-copy-confirm.show { display: inline; }

    /* HOW IT WORKS */
    .section-label { font-family: var(--mono); font-size: 0.62rem; color: var(--text-3); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; }
    .section-label::after { content: ''; flex: 1; height: 1px; background: rgba(255,255,255,0.06); }

    .steps-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2.5rem; }
    @media (max-width: 640px) { .steps-row { grid-template-columns: 1fr; } }
    .step-box { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 14px; padding: 1.4rem; position: relative; }
    .step-num { font-family: var(--mono); font-size: 0.6rem; color: var(--purple); letter-spacing: 1px; margin-bottom: 0.75rem; display: block; }
    .step-icon { font-size: 1.6rem; display: block; margin-bottom: 0.6rem; }
    .step-box h3 { font-size: 0.95rem; font-weight: 600; margin-bottom: 0.4rem; }
    .step-box p { font-size: 0.83rem; color: var(--text-2); line-height: 1.6; }

    /* BENEFITS */
    .benefits-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; margin-bottom: 2.5rem; }
    @media (max-width: 640px) { .benefits-row { grid-template-columns: 1fr; } }
    .benefit { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 10px; padding: 1rem 1.1rem; font-size: 0.85rem; color: var(--text-2); display: flex; align-items: flex-start; gap: 0.5rem; }
    .benefit-check { color: var(--green); flex-shrink: 0; font-weight: 700; margin-top: 0.1rem; }

    /* FAQ */
